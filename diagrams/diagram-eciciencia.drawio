        <!-- Design decisions -->
        <mxCell id="14" value="&lt;b&gt;Design Decisions&lt;/b&gt;&lt;hr/&gt;✓ Attendee does not know Reservation details — each service has its own data&lt;br&gt;✓ Capacity check is ReservationService responsibility — ScheduleService only stores activity info&lt;br&gt;✓ Gateway hides ports — client only calls Gateway; same pattern as Part VI (WellnessGateway)&lt;br&gt;✓ getAttendeeProfile() aggregates AttendeeService + ReservationService in one gateway call" style="text;html=1;strokeColor=#999999;fillColor=#f5f5f5;fontColor=#333333;align=left;verticalAlign=top;spacingLeft=8;overflow=hidden;fontSize=11;" vertex="1" parent="1">
